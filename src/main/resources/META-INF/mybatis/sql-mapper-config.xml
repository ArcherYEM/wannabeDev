<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0//EN" "http://mybatis.org/dtd/mybatis-3-config.dtd">

<configuration>
	<!--Mybatis 설정 -->

	<settings>
		<!-- 전통적인 데이터베이스 컬럼명 형태인 A_COLUMN을 CamelCase형태의 자바 프로퍼티명 형태인 aColumn으로 자동으로 매핑하도록 함 -->
		<setting name="jdbcTypeForNull" value="VARCHAR" />
		<setting name="callSettersOnNulls" value="true" />
		<setting name="mapUnderscoreToCamelCase" value="true" />
		<setting name="lazyLoadingEnabled" value="true" />
		<setting name="aggressiveLazyLoading" value="false" />
	</settings>

	<typeAliases>
        <typeAlias alias="map" type="java.util.Map"/>
        <typeAlias alias="hashMap" type="java.util.HashMap"/>

		<!--> VO <-->
		<typeAlias alias="UserBasic" type="com.dev.wannabe.domain.home.model.vo.user.UserBasic"/>
		<typeAlias alias="UserDetail" type="com.dev.wannabe.domain.home.model.vo.user.UserDetail"/>
		<typeAlias alias="UserRole" type="com.dev.wannabe.domain.home.model.vo.user.UserRole"/>
		<typeAlias alias="LoginLog" type="com.dev.wannabe.domain.home.model.vo.login.LoginLog"/>

		<!--> DTO <-->
		<typeAlias alias="SignupUserDTO" type="com.dev.wannabe.domain.home.model.dto.user.SignupUserDTO"/>
		<typeAlias alias="UserExistDTO" type="com.dev.wannabe.domain.home.model.dto.user.UserExistDTO"/>
		<typeAlias alias="LoginDataDTO" type="com.dev.wannabe.domain.home.model.dto.login.LoginDataDTO"/>
		<typeAlias alias="LoginLogDTO" type="com.dev.wannabe.domain.home.model.dto.login.LoginLogDTO"/>

	</typeAliases>

</configuration>