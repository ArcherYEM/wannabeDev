<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dev.wannabe.domain.home.mapper.PopupMessageMapper">

    <select id="getMessageList" resultType="com.dev.wannabe.domain.home.model.dto.PopupMessageDTO">
        SELECT *
        from FRIEND_MESSAGE
        WHERE USER_ID = #{userId}
    </select>

