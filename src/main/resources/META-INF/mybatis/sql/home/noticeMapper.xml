    <select id="getFilteredNotices" resultType="com.dev.wannabe.domain.home.model.dto.NoticeDTO">
        SELECT *
        FROM NOTICE
        WHERE 1 = 1
        <if test="noticeType != null and noticeType != ''">
            AND notice_type = #{noticeType}
        </if>
        <if test="field != null and field != '' and keyword != null and keyword != ''">
            <choose>
                <when test="field == 'title'">
                    AND notice_title LIKE CONCAT('%', #{keyword}, '%')
                </when>
                <when test="field == 'content'">
                    AND NOTICE_CONTENTS LIKE CONCAT('%', #{keyword}, '%')
                </when>
                <otherwise>
                    AND (
                    notice_title LIKE CONCAT('%', #{keyword}, '%')
                    OR NOTICE_CONTENTS LIKE CONCAT('%', #{keyword}, '%')
                    )
                </otherwise>
            </choose>
        </if>
        ORDER BY insert_dt DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="getFilteredNoticesCount" resultType="int">
        SELECT COUNT(*)
        FROM NOTICE
        WHERE 1 = 1
        <if test="noticeType != null and noticeType != ''">
            AND notice_type = #{noticeType}
        </if>
        <if test="field != null and field != '' and keyword != null and keyword != ''">
            <choose>
                <when test="field == 'title'">
                    AND notice_title LIKE CONCAT('%', #{keyword}, '%')
                </when>
                <when test="field == 'content'">
                    AND notice_contents LIKE CONCAT('%', #{keyword}, '%')
                </when>
                <otherwise>
                    AND (
                    notice_title LIKE CONCAT('%', #{keyword}, '%')
                    OR notice_contents LIKE CONCAT('%', #{keyword}, '%')
                    )
                </otherwise>
            </choose>
        </if>
    </select>




