<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dev.wannabe.domain.home.mapper.UserUpdateMapper">

    <!-- 회원정보 조회 -->
    <select id="getMyInfo" parameterType="String" resultType="com.dev.wannabe.domain.home.model.dto.SignupUserDTO">
        SELECT  login_id,
        email,
        phone_no,
        name,
        gender_code,
        birth_date
        FROM    USER_BASIC
        WHERE   name = #{userName}
    </select>

</mapper>