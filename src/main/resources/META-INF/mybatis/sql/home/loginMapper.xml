<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dev.wannabe.domain.home.mapper.LoginMapper">

    <select id="findPasswordByLoginId" parameterType="String" resultType="String">
        SELECT PASSWORD
        FROM USER_BASIC
        WHERE LOGIN_ID = #{loginId}
    </select>


</mapper>