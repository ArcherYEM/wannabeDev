<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dev.wannabe.domain.minihompi.mapper.minihompi">

    <select id="findMiniHompi" resultType="MinihompiDto">
        select *
        from hompi
        where 1=1
        <if test='loginId not in {null, ""}'>
            and owner_user_id= #{loginId}
        </if>
    </select>

</mapper>